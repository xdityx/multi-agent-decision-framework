# ============================================================
# Ollama Cloud Configuration (preferred)
# ============================================================
# Get your API key from: https://ollama.com/settings/keys
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=mistral

# Cloud models use the :cloud suffix, e.g.:
# OLLAMA_MODEL=mistral:cloud
# OLLAMA_MODEL=llama3.1:cloud

# ============================================================
# Local Ollama (alternative — no key needed)
# ============================================================
# Run: ollama serve  (then: ollama pull mistral)
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ============================================================
# Anthropic Claude (second fallback)
# ============================================================
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
